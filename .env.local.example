# 1. Copie este arquivo para .env.local (o Next.js NÃO lê o .example)
# 2. Preencha com Supabase Dashboard → Settings → API
# 3. Reinicie: npm run dev

NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_publica

# Stripe (Planos — upgrade com pagamento da diferença)
# https://dashboard.stripe.com/apikeys  (modo Test)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Webhook local: stripe listen --forward-to localhost:3000/api/billing/webhook
# Produção: https://www.toqtennis.com.br/api/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# URL pública do app (produção: https://www.toqtennis.com.br)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare (opcional — scripts/setup-cloudflare.mjs)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE=toqtennis.com.br
# VERCEL_DNS_TARGET=cname.vercel-dns.com

# Supabase service role (webhook/checkout — NUNCA no cliente, NUNCA no .example)
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key
# https://console.cloud.google.com/ — ative Maps JavaScript API + Places API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=sua_chave_google_maps
